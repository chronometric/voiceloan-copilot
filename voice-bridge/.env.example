# OpenAI
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Laravel (same key as VOICE_BRIDGE_KEY in Laravel .env)
LARAVEL_URL=http://127.0.0.1:8000
VOICE_BRIDGE_KEY=

# Inbound WebSocket (Twilio Conversation Relay or test client connects here)
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Optional: path for WS (Twilio webhook URL: wss://your-host/ws)
BRIDGE_PATH=/ws
